{
  "manifest_version": 3,
  "name": "VocaBuild — Auto-capture",
  "version": "1.0.0",
  "description": "Automatically captures words from Google's dictionary card and adds them to VocaBuild",
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.co.in/search*",
        "https://www.google.co.uk/search*",
        "https://www.google.ca/search*",
        "https://www.google.com.au/search*"
      ],
      "js": ["content-google.js"],
      "css": ["content-google.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:4173/*",
        "https://vocabuild.vercel.app/*"
      ],
      "js": ["content-vocabuild.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  }
}
